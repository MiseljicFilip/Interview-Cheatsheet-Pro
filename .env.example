# Copy to .env and fill in real values. Do not commit .env.

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/cheatsheet

# Secret for signing JWT tokens (use a long random string in production)
JWT_SECRET=your-secret-here

# Backend server port (optional, e.g. 5000)
PORT=5000

# Frontend: base URL of the API (for when frontend calls backend)
# VITE_API_URL=http://localhost:5000
